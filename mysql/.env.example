# Used by docker-compose.yml in this folder.
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=simple_robotic_arm
MYSQL_USER=app
MYSQL_PASSWORD=change-me-app

# HostPC Go server (run on the host, not inside Docker). Example after `docker compose up -d`:
# MYSQL_DSN=app:change-me-app@tcp(127.0.0.1:3306)/simple_robotic_arm?parseTime=true
